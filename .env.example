# Example environment variables for clip-srt
# Telegram bot token
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Optional: proxy used for network operations (yt-dlp, deep-translator)
PROXY_URL=http://127.0.0.1:2080

# Paths
MODEL_PATH=./whisper_model
CACHE_DIR=./cache
ARCHIVE_DIR=./archive

# Model size (tiny, base, small, etc.)
MODEL_SIZE=base

# Max concurrent processing jobs
MAX_CONCURRENT=2